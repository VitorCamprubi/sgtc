MYSQL_DATABASE=sgtc
MYSQL_USER=seu_usuario
MYSQL_PASSWORD=sua_senha
MYSQL_ROOT_PASSWORD=sua_senha_root
MYSQL_PORT=3307

JWT_SECRET=sua_chave_jwt_com_mais_de_32_caracteres

# === E-mail / Notificacoes ===
# Para Gmail: ative 2FA e gere uma App Password em https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seu_email@gmail.com
MAIL_PASSWORD=sua_app_password_de_16_caracteres
MAIL_FROM=seu_email@gmail.com
MAIL_FROM_NAME=SGTC - Sistema de Gerenciamento de Trabalhos Cientificos
# Defina como false para desativar o envio durante desenvolvimento
MAIL_ENABLED=true

# URL publica da API (usada nos links dos emails: confirmar email, confirmar reuniao etc.)
APP_API_URL=http://localhost:8080
# URL publica do front Angular
APP_WEB_URL=http://localhost:4200
